# Supabase - For Database and Auth
# Get these from your Supabase Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Calendar API
# Follow steps to create a Service Account in Google Cloud Console
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Provide the private key as a single string replacing actual newlines with \n
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour\nKey\nHere\n-----END PRIVATE KEY-----\n"
# The ID of the specific calendar you want to manage (often your primary email, or a dedicated calendar ID)
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com

# Resend - For Transactional Emails
# Get this from your Resend Dashboard -> API Keys
RESEND_API_KEY=re_123456789
# The email address you verified on Resend to send emails from
EMAIL_FROM=updates@domain.com

# mNotify - For SMS Notifications
# Get this from mNotify Dashboard -> API
MNOTIFY_API_KEY=your_mnotify_api_key_here
MNOTIFY_SENDER_ID=TACC
# The admin's phone number to receive alerts
ADMIN_PHONE=0200000000

# Vercel Cron Secret (for the daily reminder job)
CRON_SECRET=your-random-secure-string
